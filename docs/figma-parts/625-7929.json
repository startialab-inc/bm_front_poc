{
  "componentName": "TableRowLeftArticle",
  "nodeId": "625:7929",
  "figmaName": "TableRowLeft/Article",
  "category": "Organisms",
  "description": "記事テーブルの左側行セル。チェックボックス・公開状態バッジ・記事アイコン・タイトル・URLを表示する。",
  "sizes": {
    "width": 800,
    "height": "auto（コンテンツに応じた高さ）"
  },
  "layout": {
    "direction": "row",
    "padding": "12px 16px",
    "gap": "16px",
    "align": "center"
  },
  "colors": {
    "background": "#ffffff",
    "border": "#e5e5e5"
  },
  "borders": {
    "bottom": "1px solid #e5e5e5",
    "right": "1px solid #e5e5e5"
  },
  "children": {
    "checkbox": {
      "type": "icon",
      "icon": "fa-regular fa-square",
      "size": "20px",
      "color": "#2862cb"
    },
    "badge": {
      "type": "AppBadgeStatus",
      "state": "Open",
      "text": "公開中",
      "background": "#10b981",
      "height": "20px",
      "borderRadius": "6px",
      "padding": "4px 8px",
      "fontSize": "12px",
      "color": "#fafafa"
    },
    "articleIcon": {
      "type": "icon",
      "icon": "fa-solid fa-file-lines",
      "size": "14px",
      "containerWidth": "12px",
      "containerHeight": "20px",
      "color": "#64748b"
    },
    "title": {
      "type": "text",
      "fontSize": "14px",
      "lineHeight": "20px",
      "fontWeight": 400,
      "color": "#000000",
      "truncate": false,
      "sampleText": "クラウドサーカスの『Fullstar(フルスタ)』、累計ユーザー60万人超えのホームページ作成ツール『ペライチ』に導入"
    },
    "url": {
      "type": "text",
      "fontSize": "10px",
      "lineHeight": "1",
      "fontWeight": 400,
      "color": "#2862cb",
      "textDecoration": "underline",
      "sampleText": "https://dev01015.cms2.jp/media_basic/media/ownedmedia/a31"
    },
    "copyIcon": {
      "type": "icon",
      "icon": "fa-solid fa-copy",
      "size": "12px",
      "containerSize": "20px",
      "color": "#64748b"
    }
  },
  "innerLayout": {
    "contentGap": "4px（タイトル行とURL行の間）",
    "iconTitleGap": "6px（アイコンとテキストの間）",
    "urlCopyGap": "4px（URLとコピーアイコンの間）",
    "badgeContentGap": "12px（バッジとコンテンツエリアの間）"
  },
  "notes": [
    "チェックボックスは fa-regular fa-square（未選択状態のみ表示）",
    "公開状態バッジは AppBadgeStatus コンポーネントを使用",
    "記事アイコンは fa-solid fa-file-lines（14px）",
    "タイトルは複数行になる場合あり（折り返しあり）",
    "URLは10px・ブランドブルー・下線付き",
    "コピーアイコンはURLの右に配置"
  ]
}
